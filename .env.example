# ══════════════════════════════════════════════════════════════════════════════
# n8n Pulse - Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════
#
# INSTRUCTIONS:
#   1. Copy this file to .env:  cp .env.example .env
#   2. Replace all <placeholder> values with real values
#   3. NEVER commit .env to Git (it's already in .gitignore)
#
# GENERATE SECRETS:
#   openssl rand -base64 32
#
# ══════════════════════════════════════════════════════════════════════════════

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ REQUIRED SECRETS                                                            │
# │ These MUST be set before starting the application                           │
# └─────────────────────────────────────────────────────────────────────────────┘

# PostgreSQL database password
# • Use a strong random value (min 16 characters recommended)
# • Generate: openssl rand -base64 24
POSTGRES_PASSWORD=<your-strong-database-password>

# JWT signing secret for session tokens
# • MUST be at least 32 characters
# • App will refuse to start in production if shorter
# • Generate: openssl rand -base64 32
JWT_SECRET=<your-jwt-secret-minimum-32-characters>

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ APPLICATION SETTINGS                                                        │
# └─────────────────────────────────────────────────────────────────────────────┘

# Environment mode
# • production = enables security checks, fail-fast on misconfig
# • development = relaxed checks, detailed errors
APP_ENV=production

# Public URL where users access the app
# • Used for CORS, cookies, and links
# • Include protocol (https://), no trailing slash
APP_URL=https://pulse.example.com

# CORS allowed origin
# • Must match APP_URL exactly in production
# • App refuses to start if set to "*" in production
CORS_ORIGIN=https://pulse.example.com

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ COOKIE & SESSION SECURITY                                                   │
# └─────────────────────────────────────────────────────────────────────────────┘

# Secure cookie flag
# • true = cookies only sent over HTTPS (required for production)
# • false = allow HTTP (development only)
# • App refuses to start in production if false
COOKIE_SECURE=true

# Cookie SameSite policy
# • strict = most secure, may break some flows
# • lax = recommended, good balance of security/usability
# • none = least secure, requires COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# Cookie domain (optional)
# • Leave empty for single domain deployments
# • Set to ".example.com" for subdomain sharing
COOKIE_DOMAIN=

# JWT token expiry
# • Format: number + unit (s=seconds, m=minutes, h=hours, d=days)
# • Default: 30m (30 minutes)
JWT_EXPIRY=30m

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ PASSWORD & ACCOUNT LOCKOUT                                                  │
# └─────────────────────────────────────────────────────────────────────────────┘

# Minimum password length for user accounts
# • Default: 12 characters
# • Applies to setup, set-password, and reset-password
# • Passwords are also checked against a common-password denylist
PASSWORD_MIN_LENGTH=12

# Account lockout after failed login attempts
# • Default threshold: 10 attempts
# • Default duration: 15 minutes
# • Set threshold to 0 to disable lockout (not recommended)
ACCOUNT_LOCKOUT_THRESHOLD=10
ACCOUNT_LOCKOUT_DURATION_MINUTES=15

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ CONTENT SECURITY POLICY (CSP)                                               │
# └─────────────────────────────────────────────────────────────────────────────┘

# CSP report-only mode
# • false = enforce CSP (block violations) — recommended for production
# • true = report violations without blocking (useful for testing)
CSP_REPORT_ONLY=false

# CSP violation report URI (optional)
# • Leave empty to disable reporting
# • Set to a URL to receive violation reports (e.g., report-uri.com)
# CSP_REPORT_URI=

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ PROXY & NETWORK                                                             │
# └─────────────────────────────────────────────────────────────────────────────┘

# Trust proxy setting for client IP detection
# • false = direct connection, no proxy (default)
# • 1 = single reverse proxy (Traefik, Caddy, NGINX, ALB)
# • 2 = two proxies (e.g., Cloudflare + Traefik)
# • Incorrect setting = wrong IP in audit logs
TRUST_PROXY=false

# Host port to expose the frontend
# • This is the port users connect to
# • Default: 8899
HTTP_PORT=8899

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ PRIVACY & GDPR - Audit Log IP Handling                                      │
# └─────────────────────────────────────────────────────────────────────────────┘

# How to store client IPs in audit logs
# • raw = store actual IP (not GDPR compliant)
# • hashed = store SHA-256 hash (recommended for GDPR)
# • none = don't store IP at all
AUDIT_LOG_IP_MODE=hashed

# Salt for IP hashing (required if AUDIT_LOG_IP_MODE=hashed)
# • Must be at least 32 characters
# • Keep secret - if leaked, hashes can be rainbow-tabled
# • If changed, historical hash comparisons will fail
# • Generate: openssl rand -base64 32
AUDIT_LOG_IP_SALT=<your-32-char-random-salt-for-ip-hashing>

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ n8n DATA INGESTION                                                          │
# │ Optional: Create a restricted database user for n8n to write data           │
# └─────────────────────────────────────────────────────────────────────────────┘

# Ingest user credentials (leave empty to disable)
# • This user can ONLY insert/update execution data
# • Cannot access user accounts, audit logs, or RBAC
# • Use these credentials in your n8n PostgreSQL nodes
PULSE_INGEST_USER=pulse_ingest
PULSE_INGEST_PASSWORD=<your-ingest-user-password>

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ FIRST ADMIN (Optional)                                                      │
# │ Create the initial admin user automatically at startup                      │
# └─────────────────────────────────────────────────────────────────────────────┘

# Both must be set for auto-creation. Otherwise use /setup UI.
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=SecurePassword123!

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ METRICS FEATURE                                                             │
# │ Optional: Enable n8n instance health monitoring                             │
# └─────────────────────────────────────────────────────────────────────────────┘

# Enable metrics dashboard
# • Shows CPU, memory, event loop latency from n8n instances
METRICS_ENABLED=true

# Maximum time range for metrics queries (days)
# • Limits how far back users can query
# • Prevents expensive queries on large datasets
METRICS_MAX_TIME_RANGE_DAYS=30

# Maximum data points per metrics query
# • Limits response size for performance
METRICS_MAX_DATAPOINTS=1000

# Maximum rows in breakdown view (default: 50)
# METRICS_MAX_BREAKDOWN_ROWS=50

# Maximum metrics in catalog dropdown (default: 200)
# METRICS_MAX_CATALOG_SIZE=200

# Maximum values per label in filters (default: 100)
# METRICS_MAX_LABEL_VALUES=100

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ DATA RETENTION                                                              │
# │ Optional: Automatic cleanup of old execution data                           │
# └─────────────────────────────────────────────────────────────────────────────┘

# Enable automatic data retention cleanup
RETENTION_ENABLED=true

# Days to keep execution data (older data is deleted)
RETENTION_DAYS=90

# Time to run daily cleanup (24h format, HH:MM)
# • Runs once per day at this time
# • Choose off-peak hours
RETENTION_RUN_AT=03:30

# Timezone for retention schedule
# • Use IANA timezone format
RETENTION_TZ=UTC

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ DATABASE (Advanced)                                                         │
# │ Usually no need to change these                                             │
# └─────────────────────────────────────────────────────────────────────────────┘

# Database connection pool settings
# DB_POOL_MAX=20
# DB_IDLE_TIMEOUT=30000
# DB_CONNECT_TIMEOUT=5000

# Log format (json for production, dev for development)
# LOG_FORMAT=json

# Login rate limit (requests per 15-min window, default: 20)
# Increase for testing or high-traffic setups
# LOGIN_RATE_LIMIT_MAX=20

# ══════════════════════════════════════════════════════════════════════════════
# QUICK START CHECKLIST
# ══════════════════════════════════════════════════════════════════════════════
#
# [ ] Set POSTGRES_PASSWORD (strong random value)
# [ ] Set JWT_SECRET (min 32 chars, run: openssl rand -base64 32)
# [ ] Set APP_URL and CORS_ORIGIN to your domain
# [ ] Set AUDIT_LOG_IP_SALT for GDPR compliance
# [ ] Set PULSE_INGEST_PASSWORD if using n8n integration
# [ ] Run: docker compose -f docker-compose.prod.yml up -d
# [ ] Create first admin at: https://your-domain.com/setup
#
# ══════════════════════════════════════════════════════════════════════════════
